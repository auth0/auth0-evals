{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "nunjucks"]
  },
  "include": ["*.ts", "config/**/*", "runners/**/*", "agent_eval/**/*", "tests/**/*", "evals/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
