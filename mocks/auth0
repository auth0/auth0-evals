#!/bin/sh
# ─────────────────────────────────────────────────────────────────────────────
# Mock Auth0 CLI for eval runs.
#
# Real `auth0` commands require an authenticated session and mutate a live
# tenant. Evals must be hermetic: they measure whether the agent knew to run
# the correct command (checked via the `ranCommandOneOf` / `ranCommand` /
# `ranCommandsInOrder` / `wroteFile` event graders against the tool-call trace),
# NOT whether a real tenant changed. This stub lets the agent's command succeed
# deterministically — no auth, no network, no live side effects — so the agent
# doesn't see an error and thrash.
#
# It is placed on PATH ahead of any real `auth0` binary via EVAL_MOCK_BIN_DIR
# (see packages/eval-core/src/utils/env.ts). Prepending guarantees a real
# auth0 install on the host can never be hit during a run.
#
# ── Statefulness ──────────────────────────────────────────────────────────────
# The stub is *stateful within a run*: a `put guardian/factors/otp` is recorded,
# so a later `get guardian/factors` reflects otp as enabled. This lets an agent
# verify its own work (read-after-write) the way the real API behaves. State is
# a set of marker files under EVAL_MOCK_STATE_DIR — a per-run temp dir OUTSIDE
# the workspace (so graders never see it), set by run.ts locally and
# entrypoint.sh in the sandbox. If unset, we fall back to a temp dir; state is
# still coherent within a single process invocation and harmless across them.
#
# ── Extending this stub ──────────────────────────────────────────────────────
# Invocation shape: `auth0 api <method> <path> [--data '...']`.
# GET routes return a static (or state-reflected) body; write methods
# (put/patch/post) record state and echo a success payload. Paths are
# normalized so a full Management API URL routes like a bare path. Add a route
# ONLY when an eval needs the response content — unmapped writes echo
# `{"ok":true}`, unmapped reads fall through to `{}`. Do not pre-populate
# endpoints nothing tests. Full guidance: mocks/README.md.
# ─────────────────────────────────────────────────────────────────────────────

FIXTURES="$(dirname "$0")/fixtures/auth0"
STATE="${EVAL_MOCK_STATE_DIR:-${TMPDIR:-/tmp}/auth0-mock-state}"
mkdir -p "$STATE" 2>/dev/null || true

# Canonical factor list, mirroring fixtures/auth0/guardian_factors.json.
FACTORS="sms push-notification otp email duo webauthn-roaming webauthn-platform recovery-code"

case "$1" in
  api)
    # $2 = HTTP method (may be upper/lower case), $3 = API path.
    method=$(printf '%s' "$2" | tr '[:upper:]' '[:lower:]')
    path="$3"
    # Normalize the path so every form agents use routes to one bare path.
    # Agents write any of: `guardian/factors/otp`, `/api/v2/guardian/factors/otp`,
    # or the full `https://<tenant>/api/v2/guardian/factors/otp`. Strip (in order)
    # scheme+host, then a leading slash, then a leading `api/v2/` segment — so all
    # three collapse to `guardian/factors/otp`. Without this, a form that fell
    # through to `{}` read as an ambiguous non-error and made agents doubt their
    # auth and thrash hunting credentials.
    path=$(printf '%s' "$path" | sed -e 's#^https\{0,1\}://[^/]*/##' -e 's#^/*##' -e 's#^api/v2/##')
    # Remaining args (incl. --data payload) as one string for cheap matching.
    payload="$*"

    case "$method $path" in
      # ── Reads: reflect prior writes ───────────────────────────────────────
      "get guardian/factors")
        # Emit the factor list, flipping enabled=true for any factor a prior
        # `put/patch guardian/factors/<name>` recorded in this run.
        first=1
        printf '['
        for f in $FACTORS; do
          if [ -f "$STATE/factor_$f" ]; then en=true; else en=false; fi
          [ "$first" -eq 0 ] && printf ','
          first=0
          printf '{"name":"%s","enabled":%s,"trial_expired":false}' "$f" "$en"
        done
        printf ']\n'
        ;;
      "get guardian/policies")
        if [ -f "$STATE/policy_set" ]; then echo '["all-applications"]'; else echo '[]'; fi
        ;;
      # ── Writes: record state, echo success ────────────────────────────────
      "put guardian/factors/"* | "patch guardian/factors/"*)
        factor="${path##*/}"
        # Record as enabled unless the payload explicitly disables it.
        case "$payload" in
          *'"enabled": false'* | *'"enabled":false'*) rm -f "$STATE/factor_$factor" ;;
          *) touch "$STATE/factor_$factor" ;;
        esac
        echo '{"enabled":true}'
        ;;
      "put guardian/policies" | "patch guardian/policies")
        touch "$STATE/policy_set"
        echo '["all-applications"]'
        ;;
      # ── Unmapped writes: echo a non-empty success, don't fake data ────────
      # A write (put/patch/post/delete) to an unrouted path still "succeeded"
      # as far as the CLI is concerned. Returning {} read as a no-op and made
      # agents doubt the call landed; a clear success body stops that thrash
      # without pretending to return specific resource data.
      "put "* | "patch "* | "post "* | "delete "*)
        echo '{"ok":true}'
        ;;
      # ── Unmapped reads: safe minimal default — deliberately NOT faked data ─
      *)
        echo '{}'
        ;;
    esac
    ;;
  login)
    echo "✓ Successfully logged in (mock)"
    ;;
  *)
    echo "auth0 (mock): ok"
    ;;
esac

exit 0
