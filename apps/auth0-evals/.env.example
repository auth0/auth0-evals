# Copy this file to .env and fill in your key.
# The framework loads .env automatically — no need to export variables.
#
#   cp .env.example .env
#   python run.py

LLM_API_KEY=sk-your-key-here

# GitHub personal access token — required for evals that use gh CLI calls inside
# the sandbox (e.g. fetching latest SDK releases). Run `gh auth token` to get yours.
GH_TOKEN=

# Optional: Braintrust experiment tracking
# Get your API key from https://www.braintrust.dev/app/settings
BRAINTRUST_API_KEY=

# Optional: Disable Bedrock when using Claude Code, instead use Lite LLM.
# CLAUDE_CODE_USE_BEDROCK_PROXY=0

LLM_PROXY_BASE_URL=https://your-llm-proxy.example.com/v1
CLAUDE_PROXY_BASE_URL=https://your-llm-proxy.example.com
GEMINI_PROXY_BASE_URL=http://127.0.0.1:9876
CODEX_PROXY_BASE_URL=https://your-llm-proxy.example.com

# For local, when using bedrock, use:
# CLAUDE_PROXY_BASE_URL=https://your-llm-proxy.example.com/anthropic
