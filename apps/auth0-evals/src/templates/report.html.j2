<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auth0 SDK Eval Report</title>
  <style>{% include 'report.css' %}</style>
</head>
<body>

{# ── helpers ─────────────────────────────────────────────────────────────── #}

{% macro pct_cell(rate, delta, cost) %}
<td class="pct-cell">
  <span class="pct-value {{ rate | rate_css_class }}">{{ (rate * 100) | round | int }}%</span>
  {% if delta is not none %}
    {% set dp = (delta * 100) | round | int %}
    {% if dp > 0 %}
      <span class="delta delta-pos">+{{ dp }}%</span>
    {% elif dp < 0 %}
      <span class="delta delta-neg">{{ dp }}%</span>
    {% else %}
      <span class="delta delta-zero">0%</span>
    {% endif %}
  {% endif %}
  {% if cost is defined and cost is not none %}
    <span class="cell-cost">${{ "%.4f" | format(cost) }}</span>
  {% endif %}
</td>
{% endmacro %}

{% macro empty_cell() %}
<td class="empty-cell">&mdash;</td>
{% endmacro %}

{# ── summary table for a single mode ────────────────────────────────────── #}
{# Rows = models, Columns = evals                                            #}

{% macro render_summary_table_for_mode(variant, variant_grouped, evals_run, models_run, deltas) %}
{% set mode_data = variant_grouped[variant] if variant_grouped[variant] else {} %}
{% set mode_deltas = deltas[variant] if deltas[variant] else {} %}
<div class="summary-wrap">
  <table class="summary-table">
    <thead>
      <tr>
        <th class="summary-eval-heading">Model</th>
        {% for eval_id in evals_run %}
        <th class="summary-column-heading">
          <div class="summary-column-model">{{ eval_id }}</div>
        </th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for model in models_run %}
      <tr class="summary-row">
        <td class="summary-eval-id">{{ model }}</td>
        {% for eval_id in evals_run %}
          {% set result = mode_data[eval_id][model] if mode_data[eval_id] and mode_data[eval_id][model] else none %}
          {% if result and result.grader_pass_rate is not none %}
            {% set d = mode_deltas[eval_id][model] if mode_deltas[eval_id] and mode_deltas[eval_id][model] is not none else none %}
            {% set c = result.cost_usd if result.cost_usd else none %}
            {{ pct_cell(result.grader_pass_rate, d, c) }}
          {% else %}
            {{ empty_cell() }}
          {% endif %}
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endmacro %}

{# ── graders table ────────────────────────────────────────────────────────── #}

{% macro render_graders(graders) %}
<table class="graders-table">
  {% for g in graders %}
  <tr>
    <td class="grader-icon {{ 'grader-pass' if g.passed else 'grader-fail' }}">{{ "✓" if g.passed else "✗" }}</td>
    <td class="grader-name">
      <span class="grader-kind">{{ g.kind }}</span>
      {{ g.name }}
    </td>
    <td class="grader-detail">{% if g.kind == "judge" %}{{ "yes" if g.passed else "no" }}{% else %}{{ g.detail if g.detail else "" }}{% endif %}</td>
  </tr>
  {% endfor %}
</table>
{% endmacro %}

{# ── judge tab ─────────────────────────────────────────────────────────────── #}

{% macro render_judge(judge_graders) %}
{% if not judge_graders %}
<div class="tab-panel-empty">No judge graders recorded.</div>
{% else %}
<div class="judge-list">
  {% for g in judge_graders %}
  <div class="judge-entry">
    <div class="judge-verdict">
      <span class="judge-verdict-badge {{ 'judge-pass' if g.passed else 'judge-fail' }}">{{ "Pass" if g.passed else "Fail" }}</span>
      <span class="judge-question">{{ g.name }}</span>
    </div>
    {{ g.detail | judge_html | safe }}
  </div>
  {% endfor %}
</div>
{% endif %}
{% endmacro %}

{# ── score breakdown ──────────────────────────────────────────────────────── #}

{% macro render_dim_group(dims, title) %}
<tr>
  <td colspan="5" class="dimension-group-header">{{ title }}</td>
</tr>
{% for dim in dims %}
{% set weighted = dim.weighted if dim.weighted else (dim.score * dim.weight if dim.score and dim.weight else 0) %}
<tr>
  <td class="dimension-name">{{ dim.name if dim.name else "" }}</td>
  <td class="dimension-score">{{ "%.1f" | format(dim.score if dim.score else 0) }}</td>
  <td class="dimension-weight">&times; {{ "%.2f" | format(dim.weight if dim.weight else 0) }}</td>
  <td class="dimension-weighted">= {{ "%.2f" | format(weighted) }}</td>
  <td class="dimension-grade">
    {% set grade = dim.grade if dim.grade else "" %}
    <span class="grade-badge {{ grade | grade_css_class }}">{{ grade }}</span>
  </td>
</tr>
{% endfor %}
{% endmacro %}

{% macro render_score_breakdown(dimensions, overall_score, overall_grade) %}
{% set process_dims = dimensions | batch(5) | first %}
{% set output_dims = [] %}
{% if dimensions | length >= 8 %}
  {% set output_dims = [dimensions[5], dimensions[6], dimensions[7]] %}
{% endif %}
<div class="score-breakdown">
  <div class="score-breakdown-title">Score Computation</div>
  <table class="score-table">
    {{ render_dim_group(process_dims, "Process Dimensions (50%)") }}
    {% if output_dims | length > 0 %}{{ render_dim_group(output_dims, "Output Dimensions (50%)") }}{% endif %}
    <tr class="weighted-total-row">
      <td class="weighted-total-label">Weighted Total</td>
      <td colspan="3" class="weighted-total-score">{{ "%.1f" | format(overall_score) }} / 100</td>
      <td class="weighted-total-grade">
        <span class="grade-badge grade-badge--lg {{ overall_grade | grade_css_class }}">{{ overall_grade }}</span>
      </td>
    </tr>
  </table>
  <div class="score-formula">
    Process (50%): friction&times;15% + speed&times;10% + efficiency&times;10% + errors&times;5% + docs&times;10%<br>
    Output (50%): correctness&times;25% + hallucination&times;15% + security&times;10%
  </div>
</div>
{% endmacro %}

{# ── turn metrics ─────────────────────────────────────────────────────────── #}

{% macro render_turn_metrics(metrics) %}
{% if not metrics or metrics | length == 0 %}
<div class="tab-panel-empty">No LLM turns recorded.</div>
{% else %}
{% set total_in = 0 %}
{% set total_out = 0 %}
{% set total_lat = 0 %}
{% set total_cost = 0 %}
{% for m in metrics %}
  {% set total_in   = total_in   + (m.input_tokens  if m.input_tokens  else 0) %}
  {% set total_out  = total_out  + (m.output_tokens if m.output_tokens else 0) %}
  {% set total_lat  = total_lat  + (m.llm_latency   if m.llm_latency   else 0) %}
  {% set total_cost = total_cost + (m.cost_usd      if m.cost_usd      else 0) %}
{% endfor %}
<div class="metrics-body">
  <table class="metrics-table">
    <tr class="metrics-thead">
      <th class="metrics-th">Turn</th>
      <th class="metrics-th metrics-th--r">In tokens</th>
      <th class="metrics-th metrics-th--r">Out tokens</th>
      <th class="metrics-th metrics-th--r">LLM latency</th>
      <th class="metrics-th metrics-th--r">Cost</th>
      <th class="metrics-th metrics-th--c">Finish</th>
      <th class="metrics-th metrics-th--c">Tools</th>
    </tr>
    {% for m in metrics %}
    {% set fr  = m.finish_reason if m.finish_reason else "unknown" %}
    {% set lat = m.llm_latency if m.llm_latency else 0 %}
    {% set cost = m.cost_usd if m.cost_usd else 0 %}
    <tr class="metrics-row">
      <td class="metrics-td">{{ m.turn }}</td>
      <td class="metrics-td metrics-td--r">{{ m.input_tokens if m.input_tokens else 0 }}</td>
      <td class="metrics-td metrics-td--r">{{ m.output_tokens if m.output_tokens else 0 }}</td>
      <td class="metrics-td metrics-td--r {{ lat | latency_css_class }}">{{ "%.1f" | format(lat) }}s</td>
      <td class="metrics-td metrics-td--r">${{ "%.4f" | format(cost) }}</td>
      <td class="metrics-td metrics-td--c"><span class="finish-pill {{ fr | finish_css_class }}">{{ fr }}</span></td>
      <td class="metrics-td metrics-td--c metrics-td--bright">{{ m.tool_call_count if m.tool_call_count else 0 }}</td>
    </tr>
    {% endfor %}
    <tr class="metrics-total-row">
      <td class="metrics-total-label">Total</td>
      <td class="metrics-total-val">{{ total_in }}</td>
      <td class="metrics-total-val">{{ total_out }}</td>
      <td class="metrics-total-val">{{ "%.1f" | format(total_lat) }}s</td>
      <td class="metrics-total-val">${{ "%.4f" | format(total_cost) }}</td>
      <td colspan="2"></td>
    </tr>
  </table>
</div>
{% endif %}
{% endmacro %}

{# ── session trace ─────────────────────────────────────────────────────────── #}

{% macro render_session_trace(trace) %}
{% if not trace or trace | length == 0 %}
<div class="tab-panel-empty">Agent completed without using any tools.</div>
{% else %}
<div class="metrics-body">
  <table class="metrics-table">
    {% for step in trace %}
    {% set action     = step.actionType if step.actionType else "" %}
    {% set size_bytes = step.resultSizeBytes if step.resultSizeBytes else 0 %}
    <tr class="metrics-row">
      <td class="metrics-td trace-step">{{ step.step }}</td>
      <td class="trace-action"><span class="action-pill {{ action | action_css_class }}">{{ action }}</span></td>
      <td class="trace-narrative">
        <span class="trace-call">
          <code class="trace-tool">{{ step.tool if step.tool else "" }}</code>
          {%- for key, val in step.args -%}
            {%- if val | length <= 60 -%}
            <span class="trace-arg"><span class="trace-arg-key">{{ key }}</span>=<span class="trace-arg-val">{{ val }}</span></span>
            {%- endif -%}
          {%- endfor -%}
          <span class="trace-dur">{{ "%.1f" | format(step.duration if step.duration else 0) }}s</span>
          {%- if size_bytes >= 1024 %}<span class="step-badge {{ size_bytes | size_css_class }}">{{ "%.1f" | format(size_bytes / 1024) }} KB</span>{%- endif %}
          {%- if step.isRetry %}<span class="step-badge badge-retry">&#8635; retry</span>{%- endif %}
          {%- if step.recoveredFromError %}<span class="step-badge badge-recovered">&#10003; recovered</span>{%- endif %}
          {%- if step.errorCategory %}<span class="step-badge badge-error-cat">{{ step.errorCategory }}</span>{%- endif %}
        </span>
        {%- for key, val in step.args -%}
          {%- if val | length > 60 -%}
          <div class="trace-block-arg"><span class="trace-arg-key">{{ key }}</span><pre class="trace-arg-pre">{{ val }}</pre></div>
          {%- endif -%}
        {%- endfor -%}
      </td>
    </tr>
    {% endfor %}
  </table>
</div>
{% endif %}
{% endmacro %}

{# ── detail card ──────────────────────────────────────────────────────────── #}

{% macro render_detail_card(model, variant, result, card_id) %}
{% set graders_list  = result.graders if result.graders else [] %}
{% set passed        = result.graders_passed if result.graders_passed is defined else (graders_list | selectattr("passed") | list | length) %}
{% set total         = result.graders_total if result.graders_total is defined else (graders_list | length) %}
{% set rate          = result.grader_pass_rate if result.grader_pass_rate is defined else (passed / total if total else 0) %}
{% set tokens        = result.tokens if result.tokens else 0 %}
{% set cost          = result.cost_usd if result.cost_usd else 0 %}
{% set wall          = result.wall_time if result.wall_time else 0 %}
{% set rate_cls      = rate | rate_css_class %}
{% set dimensions    = result.dimensions if result.dimensions else [] %}
{% set overall_score = result.overall_score if result.overall_score is defined else none %}
{% set overall_grade = result.overall_grade if result.overall_grade is defined else none %}

{% if result.status != "success" %}
<div class="card card--error">
  <div class="card-header">
    <div>
      <span class="mode-badge">{{ variant }}</span>
      <span class="card-model">{{ model }}</span>
    </div>
    <span class="error-label">{{ result.status | upper }}</span>
  </div>
  <div class="error-message">{{ result.error | truncate_str(200) if result.error else "Agent reached the turn limit without completing the task." }}</div>
</div>
{% else %}
{% set filled      = (rate * 20) | round | int %}
{% set bar_filled  = "█" | repeat_str(filled) %}
{% set bar_empty   = "░" | repeat_str(20 - filled) %}
<div class="card">
  <div class="card-header">
    <div>
      <span class="mode-badge">{{ variant }}</span>
      <span class="card-model">{{ model }}</span>
    </div>
    <div class="card-score">
      <span class="{{ rate_cls }} card-score-value">{{ passed }}/{{ total }}</span>
      <span class="card-score-label">graders</span>
    </div>
  </div>
  <div class="progress-bar"><span class="{{ rate_cls }} mono">{{ bar_filled }}{{ bar_empty }}</span> {{ (rate * 100) | round | int }}%</div>
  {% if dimensions | length > 0 and overall_score is not none %}
  {{ render_score_breakdown(dimensions, overall_score, overall_grade) }}
  {% endif %}
  {% set judge_graders = graders_list | selectattr("kind", "equalto", "judge") | list %}
  {% set has_metrics = result.turn_metrics and result.turn_metrics | length > 0 %}
  {% set has_trace   = result.session_trace and result.session_trace | length > 0 %}
  {% set has_judge   = judge_graders | length > 0 %}
  {% set show_tabs   = has_metrics or has_trace or has_judge %}
  {% if show_tabs %}
  <div class="card-tabs">
    <input type="radio" name="tab-{{ card_id }}" id="tab-g-{{ card_id }}" checked>
    <input type="radio" name="tab-{{ card_id }}" id="tab-j-{{ card_id }}">
    <input type="radio" name="tab-{{ card_id }}" id="tab-m-{{ card_id }}">
    <input type="radio" name="tab-{{ card_id }}" id="tab-t-{{ card_id }}">
    <div class="tab-bar">
      <label class="tab-label" for="tab-g-{{ card_id }}">Graders</label>
      <label class="tab-label{% if not has_judge %} tab-label--hidden{% endif %}" for="tab-j-{{ card_id }}">Judge</label>
      <label class="tab-label{% if not has_metrics %} tab-label--hidden{% endif %}" for="tab-m-{{ card_id }}">Metrics</label>
      <label class="tab-label{% if not has_trace %} tab-label--hidden{% endif %}" for="tab-t-{{ card_id }}">Trace</label>
    </div>
    <div class="tab-panel">{{ render_graders(graders_list) }}</div>
    <div class="tab-panel">{{ render_judge(judge_graders) }}</div>
    <div class="tab-panel">{{ render_turn_metrics(result.turn_metrics) }}</div>
    <div class="tab-panel">{{ render_session_trace(result.session_trace) }}</div>
  </div>
  {% else %}
  {{ render_graders(graders_list) }}
  {% endif %}
  <div class="card-footer">
    <span>⏱ {{ "%.1f" | format(wall) }}s</span>
    <span>🔤 {{ tokens }} tokens</span>
    <span>💰 ${{ "%.4f" | format(cost) }}</span>
  </div>
</div>
{% endif %}
{% endmacro %}

{# ── detail section ───────────────────────────────────────────────────────── #}

{% macro render_detail_section(eval_id, results_for_eval) %}
<div class="detail-section">
  <h2 class="detail-section-title">{{ eval_id }}</h2>
  {% set sorted_keys = results_for_eval | sort_result_keys %}
  {% for key in sorted_keys %}
  {% set parts = key.split("|") %}
  {% set model   = parts[0] %}
  {% set variant = parts[1] %}
  {% set result = results_for_eval[key] %}
  {{ render_detail_card(model, variant, result, card_id=eval_id ~ "_" ~ loop.index) }}
  {% endfor %}
</div>
{% endmacro %}

{# ══════════════════════════════════════════════════════════════════════════ #}
{# Page body                                                                  #}
{# ══════════════════════════════════════════════════════════════════════════ #}

  <div class="page-header">
    <h1 class="page-title">Auth0 SDK &mdash; Eval Report</h1>
    <div class="page-date">{{ generated_at }}</div>
    <div class="page-stats">
      <span><strong class="stat-value">{{ total_runs }}</strong> runs</span>
      <span><strong class="stat-value">{{ evals_run | length }}</strong> evals</span>
      <span><strong class="stat-value">{{ models_run | join(", ") }}</strong></span>
      <span>total cost <strong class="stat-value">${{ "%.4f" | format(total_cost) }}</strong></span>
    </div>
  </div>

  <h2 class="section-heading">Summary</h2>

  {# Variant toggle buttons #}
  <div class="mode-toggle">
    {% for variant in variants_present %}
    <button class="mode-toggle-btn {{ 'active' if loop.first }}" data-variant="{{ variant }}">{{ variant }}</button>
    {% endfor %}
  </div>

  {# One summary panel per variant #}
  {% for variant in variants_present %}
  <div class="summary-panel {{ 'active' if loop.first }}" data-variant="{{ variant }}">
    {{ render_summary_table_for_mode(variant, variant_grouped, evals_run, models_run, deltas) }}
  </div>
  {% endfor %}

  <h2 class="section-heading section-heading--details">Details</h2>
  {% for eval_id in grouped_sorted_keys %}
  {{ render_detail_section(eval_id, grouped[eval_id]) }}
  {% endfor %}

  <div class="page-footer">Generated by auth0-evals</div>

<script>
// Summary variant toggle
document.querySelectorAll('.mode-toggle-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var variant = btn.getAttribute('data-variant');
    document.querySelectorAll('.mode-toggle-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    document.querySelectorAll('.summary-panel').forEach(function(p) { p.classList.remove('active'); });
    var target = document.querySelector('.summary-panel[data-variant="' + variant + '"]');
    if (target) target.classList.add('active');
  });
});
</script>
</body>
</html>
