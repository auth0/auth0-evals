{
  "name": "auth0-evals",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint \"./**/*.ts\"",
    "format": "prettier --write \"./**/*.ts\"",
    "prepare": "husky",
    "prerun": "npm run build",
    "run": "node dist/run.js",
    "prereport": "npm run build",
    "report": "node dist/report.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.109",
    "@github/copilot-sdk": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "braintrust": "^3.7.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "marked": "^17.0.5",
    "nunjucks": "^3.2.4",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/nunjucks": "^3.2.6",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
