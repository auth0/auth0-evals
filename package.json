{
  "name": "auth0-evals-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "evals": "turbo run evals --",
    "run": "turbo run evals --",
    "report": "turbo run report --",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "lint": "turbo run lint",
    "format": "prettier --write \"./**/*.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@actions/core": "^3.0.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
