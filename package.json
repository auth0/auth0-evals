{
  "name": "auth0-evals-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "run": "turbo run run --",
    "report": "turbo run report --",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "lint": "turbo run lint",
    "format": "prettier --write \"./**/*.ts\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
