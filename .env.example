# Copy this file to .env and fill in your key.
# The framework loads .env automatically — no need to export variables.
#
#   cp .env.example .env
#   python run.py

ATKO_API_KEY=sk-your-key-here

# Optional: Braintrust experiment tracking
# Get your API key from https://www.braintrust.dev/app/settings
BRAINTRUST_API_KEY=

# Optional: Skills resolution source
#   auto   (default) — try remote GitHub first, fall back to local ./skills/
#   local             — read only from SKILLS_LOCAL_DIR, no network calls
#   remote            — read only from remote GitHub (original behaviour)
# SKILLS_SOURCE=auto

# Optional: Path to the local skills directory (default: ./skills)
# Directory layout must mirror the remote repo: {name}/SKILL.md
# SKILLS_LOCAL_DIR=./skills
