{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"],
      "outputLogs": "new-only"
    },
    "run": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["*"],
      "outputLogs": "new-only"
    },
    "report": {
      "dependsOn": ["build"],
      "cache": false,
      "passThroughEnv": ["*"],
      "outputLogs": "new-only"
    },
    "test": {
      "dependsOn": ["build"],
      "outputLogs": "new-only"
    },
    "test:ci": {
      "dependsOn": ["build"],
      "outputLogs": "new-only"
    },
    "lint": {
      "outputLogs": "new-only"
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "new-only"
    }
  }
}
