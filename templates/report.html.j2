<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auth0 SDK Eval Report</title>
  <style>{% include 'report.css' %}</style>
</head>
<body>

{# ── helpers ─────────────────────────────────────────────────────────────── #}

{% macro pct_cell(rate) %}
<td class="pct-cell"><span class="pct-value {{ grade_class(rate) }}">{{ (rate * 100) | round | int }}%</span></td>
{% endmacro %}

{% macro empty_cell() %}
<td class="empty-cell">—</td>
{% endmacro %}

{# ── summary table ────────────────────────────────────────────────────────── #}

{% macro render_summary_table(grouped, all_keys) %}
<div class="summary-wrap">
  <table class="summary-table">
    <thead>
      <tr>
        <th class="summary-eval-heading">Eval</th>
        {% for model, mode in all_keys %}
        <th class="summary-column-heading">
          <div class="summary-column-mode">{{ mode }}</div>
          <div class="summary-column-model">{{ model }}</div>
        </th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for eval_id in grouped | sort %}
      <tr class="summary-row">
        <td class="summary-eval-id">{{ eval_id }}</td>
        {% for model, mode in all_keys %}
        {% set result = grouped[eval_id].get(model ~ "|" ~ mode) %}
        {% if result and result.get("grader_pass_rate") is not none %}
          {{ pct_cell(result["grader_pass_rate"]) }}
        {% else %}
          {{ empty_cell() }}
        {% endif %}
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% endmacro %}

{# ── graders table ────────────────────────────────────────────────────────── #}

{% macro render_graders(graders) %}
<table class="graders-table">
  {% for g in graders %}
  <tr>
    <td class="grader-icon {{ 'grader-icon--pass' if g['passed'] else 'grader-icon--fail' }}">{{ "✓" if g["passed"] else "✗" }}</td>
    <td class="grader-name">
      <span class="grader-kind">{{ g["kind"] }}</span>{{ g["name"] }}
    </td>
    <td class="grader-detail">{{ g.get("detail", "") }}</td>
  </tr>
  {% endfor %}
</table>
{% endmacro %}

{# ── score breakdown ──────────────────────────────────────────────────────── #}

{% macro render_dim_group(dims, title) %}
{% set badge_class = {"A": "badge-a", "B": "badge-b", "C": "badge-c", "D": "badge-df", "F": "badge-df"} %}
<tr>
  <td colspan="5" class="dimension-group-header">{{ title }}</td>
</tr>
{% for dim in dims %}
{% set weighted = dim.get("weighted", dim.get("score", 0) * dim.get("weight", 0.0)) %}
<tr>
  <td class="dimension-name">{{ dim.get("name", "") }}</td>
  <td class="dimension-score">{{ "%.1f" | format(dim.get("score", 0)) }}</td>
  <td class="dimension-weight">× {{ "%.2f" | format(dim.get("weight", 0.0)) }}</td>
  <td class="dimension-weighted">= {{ "%.2f" | format(weighted) }}</td>
  <td class="dimension-grade">
    <span class="badge badge-sm {{ badge_class.get(dim.get('grade', ''), '') }}">{{ dim.get("grade", "") }}</span>
  </td>
</tr>
{% endfor %}
{% endmacro %}

{% macro render_score_breakdown(dimensions, overall_score, overall_grade) %}
{% set badge_class = {"A": "badge-a", "B": "badge-b", "C": "badge-c", "D": "badge-df", "F": "badge-df"} %}
{% set process_dims = dimensions if dimensions | length < 5 else dimensions[:5] %}
{% set output_dims  = dimensions[5:8] if dimensions | length >= 8 else [] %}
<div class="score-breakdown">
  <div class="score-breakdown-title">Score Computation</div>
  <table class="score-table">
    {{ render_dim_group(process_dims, "Process Dimensions (50%)") }}
    {% if output_dims %}{{ render_dim_group(output_dims, "Output Dimensions (50%)") }}{% endif %}
    <tr class="weighted-total-row">
      <td class="weighted-total-label">Weighted Total</td>
      <td colspan="3" class="weighted-total-score">{{ "%.1f" | format(overall_score) }} / 100</td>
      <td class="weighted-total-grade">
        <span class="badge badge-lg {{ badge_class.get(overall_grade, '') }}">{{ overall_grade }}</span>
      </td>
    </tr>
  </table>
  <div class="score-formula">
    Process (50%): friction×15% + speed×10% + efficiency×10% + errors×5% + docs×10%<br>
    Output (50%): correctness×25% + hallucination×15% + security×10%
  </div>
</div>
{% endmacro %}

{# ── detail card ──────────────────────────────────────────────────────────── #}

{% macro render_detail_card(model, mode, result) %}
{% set graders_list  = result.get("graders", []) %}
{% set passed        = result.get("graders_passed", graders_list | selectattr("passed") | list | length) %}
{% set total         = result.get("graders_total",  graders_list | length) %}
{% set rate          = result.get("grader_pass_rate", (passed / total if total else 0)) %}
{% set tokens        = result.get("tokens", 0) %}
{% set cost          = result.get("cost_usd", 0) %}
{% set wall          = result.get("wall_time", 0) %}
{% set rate_cls      = grade_class(rate) %}
{% set dimensions    = result.get("dimensions", []) %}
{% set overall_score = result.get("overall_score") %}
{% set overall_grade = result.get("overall_grade") %}

{% if result.get("status") == "error" %}
<div class="card card--error">
  <div class="card-header">
    <div>
      <span class="mode-badge">{{ mode }}</span>
      <span class="card-model">{{ model }}</span>
    </div>
    <span class="error-label">ERROR</span>
  </div>
  <div class="error-message">{{ result.get("error", "Unknown error")[:200] }}</div>
</div>
{% else %}
{% set filled      = (rate * 20) | round | int %}
{% set bar_filled  = "█" * filled %}
{% set bar_empty   = "░" * (20 - filled) %}
<div class="card">
  <div class="card-header">
    <div>
      <span class="mode-badge">{{ mode }}</span>
      <span class="card-model">{{ model }}</span>
    </div>
    <div class="card-score">
      <span class="card-score-value {{ rate_cls }}">{{ passed }}/{{ total }}</span>
      <span class="card-score-label">graders</span>
    </div>
  </div>
  <div class="progress-bar"><span class="mono {{ rate_cls }}">{{ bar_filled }}{{ bar_empty }}</span> {{ (rate * 100) | round | int }}%</div>
  {% if dimensions and overall_score is not none %}
  {{ render_score_breakdown(dimensions, overall_score, overall_grade) }}
  {% endif %}
  {{ render_graders(graders_list) }}
  <div class="card-footer">
    <span>⏱ {{ "%.1f" | format(wall) }}s</span>
    <span>🔤 {{ "{:,}".format(tokens) }} tokens</span>
    <span>💰 ${{ "%.4f" | format(cost) }}</span>
  </div>
</div>
{% endif %}
{% endmacro %}

{# ── detail section ───────────────────────────────────────────────────────── #}

{% macro render_detail_section(eval_id, results_for_eval) %}
<div class="detail-section">
  <h2 class="detail-section-title">{{ eval_id }}</h2>
  {% set sorted_keys = results_for_eval.keys() | sort_result_keys %}
  {% for key in sorted_keys %}
  {% set parts = key.split("|", 1) %}
  {% set model = parts[0] %}
  {% set mode  = parts[1] %}
  {% set result = results_for_eval[key] %}
  {{ render_detail_card(model, mode, result) }}
  {% endfor %}
</div>
{% endmacro %}

{# ══════════════════════════════════════════════════════════════════════════ #}
{# Page body                                                                  #}
{# ══════════════════════════════════════════════════════════════════════════ #}

  <div class="page-header">
    <h1 class="page-title">Auth0 SDK — Eval Report</h1>
    <div class="page-date">{{ generated_at }}</div>
    <div class="page-stats">
      <span><strong class="stat-value">{{ total_runs }}</strong> runs</span>
      <span><strong class="stat-value">{{ grouped | length }}</strong> evals</span>
      <span><strong class="stat-value">{{ models_run | join(", ") }}</strong></span>
      <span>total cost <strong class="stat-value">${{ "%.4f" | format(total_cost) }}</strong></span>
    </div>
    <div>
      {% for m in modes_run %}
      <span class="mode-badge">{{ m }}</span>
      {% endfor %}
    </div>
  </div>

  <h2 class="section-heading">Summary</h2>
  {{ render_summary_table(grouped, all_keys) }}

  <h2 class="section-heading section-heading--details">Details</h2>
  {% for eval_id in grouped | sort %}
  {{ render_detail_section(eval_id, grouped[eval_id]) }}
  {% endfor %}

  <div class="page-footer">Generated by auth0-evals</div>
</body>
</html>
